    "text": "\u0648\u064e\u0645\u064e\u0627 \u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0627\u0653 \u0623\u064e\u0635\u0652\u062d\u064e\u0670\u0628\u064e \u0671\u0644\u0646\u0651\u064e\u0627\u0631\u0650 \u0625\u0650\u0644\u0651\u064e\u0627 \u0645\u064e\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e\u0629\u064b\u06ed \u06d9 \u0648\u064e\u0645\u064e\u0627 \u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0627 \u0639\u0650\u062f\u0651\u064e\u062a\u064e\u0647\u064f\u0645\u0652 \u0625\u0650\u0644\u0651\u064e\u0627 \u0641\u0650\u062a\u0652\u0646\u064e\u0629\u064b\u06ed \u0644\u0651\u0650\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0644\u0650\u064a\u064e\u0633\u0652\u062a\u064e\u064a\u0652\u0642\u0650\u0646\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064f\u0648\u062a\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064e \u0648\u064e\u064a\u064e\u0632\u0652\u062f\u064e\u0627\u062f\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u064a\u0645\u064e\u0670\u0646\u064b\u06ed\u0627 \u06d9 \u0648\u064e\u0644\u064e\u0627 \u064a\u064e\u0631\u0652\u062a\u064e\u0627\u0628\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064f\u0648\u062a\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064e \u0648\u064e\u0671\u0644\u0652\u0645\u064f\u0624\u0652\u0645\u0650\u0646\u064f\u0648\u0646\u064e \u06d9 \u0648\u064e\u0644\u0650\u064a\u064e\u0642\u064f\u0648\u0644\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0641\u0650\u0649 \u0642\u064f\u0644\u064f\u0648\u0628\u0650\u0647\u0650\u0645 \u0645\u0651\u064e\u0631\u064e\u0636\u064c\u06ed \u0648\u064e\u0671\u0644\u0652\u0643\u064e\u0670\u0641\u0650\u0631\u064f\u0648\u0646\u064e \u0645\u064e\u0627\u0630\u064e\u0627\u0653 \u0623\u064e\u0631\u064e\u0627\u062f\u064e \u0671\u064