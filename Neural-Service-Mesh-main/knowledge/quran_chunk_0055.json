    "text_norm": "\u0648\u0645\u0627 \u062c\u0639\u0644\u0646\u0627 \u0627\u0635\u062d\u0628 \u0627\u0644\u0646\u0627\u0631 \u0627\u0644\u0627 \u0645\u0644\u0626\u0643\u0629\u06ed \u06d9 \u0648\u0645\u0627 \u062c\u0639\u0644\u0646\u0627 \u0639\u062f\u062a\u0647\u0645 \u0627\u0644\u0627 \u0641\u062a\u0646\u0629\u06ed \u0644\u0644\u0630\u064a\u0646 \u0643\u0641\u0631\u0648\u0627\u06df \u0644\u064a\u0633\u062a\u064a\u0642\u0646 \u0627\u0644\u0630\u064a\u0646 \u0627\u0648\u062a\u0648\u0627\u06df \u0627\u0644\u0643\u062a\u0628 \u0648\u064a\u0632\u062f\u0627\u062f \u0627\u0644\u0630\u064a\u0646 \u0621\u0627\u0645\u0646\u0648\u0627\u06df \u0627\u064a\u0645\u0646\u06ed\u0627 \u06d9 \u0648\u0644\u0627 \u064a\u0631\u062a\u0627\u0628 \u0627\u0644\u0630\u064a\u0646 \u0627\u0648\u062a\u0648\u0627\u06df \u0627\u0644\u0643\u062a\u0628 \u0648\u0627\u0644\u0645\u0624\u0645\u0646\u0648\u0646 \u06d9 \u0648\u0644\u064a\u0642\u0648\u0644 \u0627\u0644\u0630\u064a\u0646 \u0641\u0649 \u0642\u0644\u0648\u0628\u0647\u0645 \u0645\u0631\u0636\u06ed \u0648\u0627\u0644\u0643\u0641\u0631\u0648\u0646 \u0645\u0627\u0630\u0627 \u0627\u0631\u0627\u062f \u0627\u0644\u0644\u0647 \u0628\u0647\u0630\u0627 \u0645\u062b\u0644\u06ed\u0627 \u06da \u0643\u0630\u0644\u0643 \u064a\u0636\u0644 \u0627\u0644\u0644\u0647 \u0645\u0646 \u064a\u0634\u0627\u0621 \u0648\u064a\u0647\u062f\u0649 \u0645\u0646 \u064a\u0634\u0627\u0621 \u06da \u0648\u0645\u0627 \u064a\u0639\u0644\u0645 \u062c\u0646\u0648\u062f \u0631\u0628\u0643 \u0627\u0644\u0627 \u0647\u0648 \u06da \u0648\u0645\u0627 \u0647\u0649 \u0627\u0644\u0627 \u0630\u0643\u0631\u0649 \u0644\u0644\u0628\u0634\u0631"
