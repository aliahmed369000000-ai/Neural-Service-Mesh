    "text_norm": "\u0627\u0646\u0627 \u0627\u0639\u062a\u062f\u0646\u0627 \u0644\u0644\u0643\u0641\u0631\u064a\u0646 \u0633\u0644\u0633\u0644\u0627\u06df \u0648\u0627\u063a\u0644\u0644\u06ed\u0627 \u0648\u0633\u0639\u064a\u0631\u0627"
