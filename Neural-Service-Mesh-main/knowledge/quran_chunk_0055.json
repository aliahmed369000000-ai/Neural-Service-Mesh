    "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0647\u064e\u0644\u0652 \u0623\u064e\u062a\u064e\u0649\u0670 \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u0650 \u062d\u0650\u064a\u0646\u064c\u06ed \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u062f\u0651\u064e\u0647\u0652\u0631\u0650 \u0644\u064e\u0645\u0652 \u064a\u064e\u0643\u064f\u0646 \u0634\u064e\u064a\u0652\u0640\u0654\u064b\u06ed\u0627 \u0645\u0651\u064e\u0630\u0652\u0643\u064f\u0648\u0631\u064b\u0627",
    "text_norm": "\u0628\u0633\u0645 \u0627\u0644\u0644\u0647 \u0627\u0644\u0631\u062d\u0645\u0646 \u0627\u0644\u0631\u062d\u064a\u0645 \u0647\u0644 \u0627\u062a\u0649 \u0639\u0644\u0649 \u0627\u0644\u0627\u0646\u0633\u0646 \u062d\u064a\u0646\u06ed \u0645\u0646 \u0627\u0644\u062f\u0647\u0631 \u0644\u0645 \u064a\u0643\u0646 \u0634\u064a\u06ed\u0627 \u0645\u0630\u0643\u0648\u0631\u0627"
  },
  {
    "surah": 76,
    "ayah": 2,
    "text": "\u0625\u0650\u0646\u0651\u064e\u0627 \u062e\u064e\u0644\u064e\u0642\u0652\u0646\u064e\u0627 \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0645\u0650\u0646 \u0646\u0651\u064f\u0637\u0652\u0641\u064e\u0629\u064d \u0623\u064e\u0645\u0652\u0634\u064e\u0627\u062c\u064d\u06e2 \u0646\u0651\u064e\u0628\u0652\u062a\u064e\u0644\u0650\u064a\u0647\u0650 \u0641\u064e\u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0670\u0647\u064f \u0633\u064e\u0645\u0650\u064a\u0639\u064b\u06e2\u0627 \u0628\u064e\u0635\u0650\u064a\u0631\u064b\u0627",
    "text_norm": "\u0627\u0646\u0627 \u062e\u0644\u0642\u0646\u0627 \u0627\u0644\u0627\u0646\u0633\u0646 \u0645\u0646 \u0646\u0637\u0641\u0629 \u0627\u0645\u0634\u0627\u062c\u06e2 \u0646\u0628\u062a\u0644\u064a\u0647 \u0641\u062c\u0639\u0644\u0646\u0647 \u0633\u0645\u064a\u0639\u06e2\u0627 \u0628\u0635\u064a\u0631\u0627"
  },
  {
    "surah": 76,
    "ayah": 3,
    "text": "\u0625\u0650\u0646\u0651\u064e\u0627 \u0647\u064e\u062f\u064e\u064a\u0652\u0646\u064e\u0670\u0647\u064f \u0671\u0644\u0633\u0651\u064e\u0628\u0650\u064a\u0644\u064e \u0625\u0650\u0645\u0651\u064e\u0627 \u0634\u064e\u0627\u0643\u0650\u0631\u064b\u06ed\u0627 \u0648\u064e\u0625\u0650\u0645\u0651\u064e\u0627 \u0643\u064e\u0641\u064f\u0648\u0631\u064b\u0627",
    "text_norm": "\u0627\u0646\u0627 \u0647\u062f\u064a\u0646\u0647 \u0627\u0644\u0633\u0628\u064a\u0644 \u0627\u0645\u0627 \u0634\u0627\u0643\u0631\u06ed\u0627 \u0648\u0627\u0645\u0627 \u0643\u0641\u0648\u0631\u0627"
  },
  {
