    "text": "\u0648\u064e\u064a\u064f\u0637\u0652\u0639\u0650\u0645\u064f\u0648\u0646\u064e \u0671\u0644\u0637\u0651\u064e\u0639\u064e\u0627\u0645\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u062d\u064f\u0628\u0651\u0650\u0647\u0650\u06e6 \u0645\u0650\u0633\u0652\u0643\u0650\u064a\u0646\u064b\u06ed\u0627 \u0648\u064e\u064a\u064e\u062a\u0650\u064a\u0645\u064b\u06ed\u0627 \u0648\u064e\u0623\u064e\u0633\u0650\u064a\u0631\u064b\u0627",
    "text_norm": "\u0648\u064a\u0637\u0639\u0645\u0648\u0646 \u0627\u0644\u0637\u0639\u0627\u0645 \u0639\u0644\u0649 \u062d\u0628\u0647\u06e6 \u0645\u0633\u0643\u064a\u0646\u06ed\u0627 \u0648\u064a\u062a\u064a\u0645\u06ed\u0627 \u0648\u0627\u0633\u064a\u0631\u0627"
