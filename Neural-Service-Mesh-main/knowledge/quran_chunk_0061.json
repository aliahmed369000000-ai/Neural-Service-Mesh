    "text": "\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0644\u064e\u0645\u0652 \u064a\u064e\u0643\u064f\u0646\u0650 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0645\u0650\u0646\u0652 \u0623\u064e\u0647\u0652\u0644\u0650 \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u0650 \u0648\u064e\u0671\u0644\u0652\u0645\u064f\u0634\u0652\u0631\u0650\u0643\u0650\u064a\u0646\u064e \u0645\u064f\u0646\u0641\u064e\u0643\u0651\u0650\u064a\u0646\u064e \u062d\u064e\u062a\u0651\u064e\u0649\u0670 \u062a\u064e\u0623\u0652\u062a\u0650\u064a\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0628\u064e\u064a\u0651\u0650\u0646\u064e\u0629\u064f",
    "text_norm": "\u0628\u0633\u0645 \u0627\u0644\u0644\u0647 \u0627\u0644\u0631\u062d\u0645\u0646 \u0627\u0644\u0631\u062d\u064a\u0645 \u0644\u0645 \u064a\u0643\u0646 \u0627\u0644\u0630\u064a\u0646 \u0643\u0641\u0631\u0648\u0627\u06df \u0645\u0646 \u0627\u0647\u0644 \u0627\u0644\u0643\u062a\u0628 \u0648\u0627\u0644\u0645\u0634\u0631\u0643\u064a\u0646 \u0645\u0646\u0641\u0643\u064a\u0646 \u062d\u062a\u0649 \u062a\u0627\u062a\u064a\u0647\u0645 \u0627\u0644\u0628\u064a\u0646\u0629"
  },
  {
    "surah": 98,
    "ayah": 2,
    "text": "\u0631\u064e\u0633\u064f\u0648\u0644\u064c\u06ed \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u064a\u064e\u062a\u0652\u0644\u064f\u0648\u0627\u06df \u0635\u064f\u062d\u064f\u0641\u064b\u06ed\u0627 \u0645\u0651\u064f\u0637\u064e\u0647\u0651\u064e\u0631\u064e\u0629\u064b\u06ed",
    "text_norm": "\u0631\u0633\u0648\u0644\u06ed \u0645\u0646 \u0627\u0644\u0644\u0647 \u064a\u062a\u0644\u0648\u0627\u06df \u0635\u062d\u0641\u06ed\u0627 \u0645\u0637\u0647\u0631\u0629\u06ed"
  },
  {
    "surah": 98,
