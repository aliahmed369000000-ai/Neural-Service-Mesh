    "text": "\u062c\u064e\u0632\u064e\u0627\u0653\u0624\u064f\u0647\u064f\u0645\u0652 \u0639\u0650\u0646\u062f\u064e \u0631\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u0652 \u062c\u064e\u0646\u0651\u064e\u0670\u062a\u064f \u0639\u064e\u062f\u0652\u0646\u064d\u06e2 \u062a\u064e\u062c\u0652\u0631\u0650\u0649 \u0645\u0650\u0646 \u062a\u064e\u062d\u0652\u062a\u0650\u0647\u064e\u0627 \u0671\u0644\u0652\u0623\u064e\u0646\u0652\u0647\u064e\u0670\u0631\u064f \u062e\u064e\u0670\u0644\u0650\u062f\u0650\u064a\u0646\u064e \u0641\u0650\u064a\u0647\u064e\u0627\u0653 \u0623\u064e\u0628\u064e\u062f\u064b\u06ed\u0627 \u06d6 \u0631\u0651\u064e\u0636\u0650\u0649\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0646\u0652\u0647\u064f\u0645\u0652 \u0648\u064e\u0631\u064e\u0636\u064f\u0648\u0627\u06df \u0639\u064e\u0646\u0652\u0647\u064f \u06da \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0644\u0650\u0645\u064e\u0646\u0652 \u062e\u064e\u0634\u0650\u0649\u064e \u0631\u064e\u0628\u0651\u064e\u0647\u064f\u06e5",
    "text_norm": "\u062c\u0632\u0627\u0624\u0647\u0645 \u0639\u0646\u062f \u0631\u0628\u0647\u0645 \u062c\u0646\u062a \u0639\u062f\u0646\u06e2 \u062a\u062c\u0631\u0649 \u0645\u0646 \u062a\u062d\u062a\u0647\u0627 \u0627\u0644\u0627\u0646\u0647\u0631 \u062e\u0644\u062f\u064a\u0646 \u0641\u064a\u0647\u0627 \u0627\u0628\u062f\u06ed\u0627 \u06d6 \u0631\u0636\u0649 \u0627\u0644\u0644\u0647 \u0639\u0646\u0647\u0645 \u0648\u0631\u0636\u0648\u0627\u06df \u0639\u0646\u0647 \u06da \u0630\u0644\u0643 \u0644\u0645\u0646 \u062e\u0634\u0649 \u0631\u0628\u0647\u06e5"
