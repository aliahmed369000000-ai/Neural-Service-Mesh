  {
    "surah": 98,
    "ayah": 4,
    "text": "\u0648\u064e\u0645\u064e\u0627 \u062a\u064e\u0641\u064e\u0631\u0651\u064e\u0642\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064f\u0648\u062a\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0645\u064e\u0627 \u062c\u064e\u0627\u0653\u0621\u064e\u062a\u0652\u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0628\u064e\u064a\u0651\u0650\u0646\u064e\u0629\u064f",
    "text_norm": "\u0648\u0645\u0627 \u062a\u0641\u0631\u0642 \u0627\u0644\u0630\u064a\u0646 \u0627\u0648\u062a\u0648\u0627\u06df \u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0627 \u0645\u0646\u06e2 \u0628\u0639\u062f \u0645\u0627 \u062c\u0627\u0621\u062a\u0647\u0645 \u0627\u0644\u0628\u064a\u0646\u0629"
  },
  {
    "surah": 98,
    "ayah": 5,
    "text": "\u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064f\u0645\u0650\u0631\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0644\u0651\u064e\u0627 \u0644\u0650\u064a\u064e\u0639\u0652\u0628\u064f\u062f\u064f\u0648\u0627\u06df \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0645\u064f\u062e\u0652\u0644\u0650\u0635\u0650\u064a\u0646\u064e \u0644\u064e\u0647\u064f \u0671\u0644\u062f\u0651\u0650\u064a\u0646\u064e \u062d\u064f\u0646\u064e\u0641\u064e\u0627\u0653\u0621\u064e \u0648\u064e\u064a\u064f\u0642\u0650\u064a\u0645\u064f\u0648\u0627\u06df \u0671\u0644\u0635\u0651\u064e\u0644\u064e\u0648\u0670\u0629\u064e \u0648\u064e\u064a\u064f\u0624\u0652\u062a\u064f\u0648\u0627\u06df \u0671\u0644\u0632\u0651\u064e\u0643\u064e\u0648\u0670\u0629\u064e \u06da \u0648\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u062f\u0650\u064a\u0646\u064f \u0671\u0644\u0652\u0642\u064e\u064a\u0651\u0650\u0645\u064e\u0629\u0650",
    "text_norm": "\u0648\u0645\u0627 \u0627\u0645\u0631\u0648\u0627\u06df \u0627\u0644\u0627 \u0644\u064a\u0639\u0628\u062f\u0648\u0627\u06df \u0627\u0644\u0644\u0647 \u0645\u062e\u0644\u0635\u064a\u0646 \u0644\u0647 \u0627\u0644\u062f\u064a\u0646 \u062d\u0646\u0641\u0627\u0621 \u0648\u064a\u0642\u064a\u0645\u0648\u0627\u06df \u0627\u0644\u0635\u0644\u0648\u0629 \u0648\u064a\u0624\u062a\u0648\u0627\u06df \u0627\u0644\u0632\u0643\u0648\u0629 \u06da \u0648\u0630\u0644\u0643 \u062f\u064a\u0646 \u0627\u0644\u0642\u064a\u0645\u0629"
  },
  {
    "surah": 98,
    "ayah": 6,
    "text": "\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0645\u0650\u0646\u0652 \u0623\u064e\u0647\u0652\u0644\u0650 \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u0650 \u0648\u064e\u0671\u0644\u0652\u0645\u064f\u0634\u0652\u0631\u0650\u0643\u0650\u064a\u0646\u064e \u0641\u0650\u0649 \u0646\u064e\u0627\u0631\u0650 \u062c\u064e\u0647\u064e\u0646\u0651\u064e\u0645\u064e \u062e\u064e\u0670\u0644\u0650\u062f\u0650\u064a\u0646\u064e \u0641\u0650\u064a\u0647\u064e\u0627\u0653 \u06da \u0623\u064f\u0648\u06df\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e \u0647\u064f\u0645\u0652 \u0634\u064e\u0631\u0651\u064f \u0671\u0644\u0652\u0628\u064e\u0631\u0650\u064a\u0651\u064e\u0629\u0650",
    "text_norm": "\u0627\u0646 \u0627\u0644\u0630\u064a\u0646 \u0643\u0641\u0631\u0648\u0627\u06df \u0645\u0646 \u0627\u0647\u0644 \u0627\u0644\u0643\u062a\u0628 \u0648\u0627\u0644\u0645\u0634\u0631\u0643\u064a\u0646 \u0641\u0649 \u0646\u0627\u0631 \u062c\u0647\u0646\u0645 \u062e\u0644\u062f\u064a\u0646 \u0641\u064a\u0647\u0627 \u06da \u0627\u0648\u06df\u0644\u0626\u0643 \u0647\u0645 \u0634\u0631 \u0627\u0644\u0628\u0631\u064a\u0629"
