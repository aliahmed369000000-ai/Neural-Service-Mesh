    "text": "\u0641\u0650\u064a\u0647\u064e\u0627 \u0643\u064f\u062a\u064f\u0628\u064c\u06ed \u0642\u064e\u064a\u0651\u0650\u0645\u064e\u0629\u064c\u06ed",
    "text_norm": "\u0641\u064a\u0647\u0627 \u0643\u062a\u0628\u06ed \u0642\u064a\u0645\u0629\u06ed"
