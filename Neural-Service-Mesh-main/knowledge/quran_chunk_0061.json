    "text_norm": "\u0627\u0646 \u0627\u0644\u0630\u064a\u0646 \u0621\u0627\u0645\u0646\u0648\u0627\u06df \u0648\u0639\u0645\u0644\u0648\u0627\u06df \u0627\u0644\u0635\u0644\u062d\u062a \u0627\u0648\u06df\u0644\u0626\u0643 \u0647\u0645 \u062e\u064a\u0631 \u0627\u0644\u0628\u0631\u064a\u0629"
