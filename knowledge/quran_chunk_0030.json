    "text": "\u0625\u0650\u0630\u0652 \u0642\u064e\u0627\u0644\u064e \u0644\u064e\u0647\u064f\u0645\u0652 \u0623\u064e\u062e\u064f\u0648\u0647\u064f\u0645\u0652 \u0644\u064f\u0648\u0637\u064c \u0623\u064e\u0644\u064e\u0627 \u062a\u064e\u062a\u0651\u064e\u0642\u064f\u0648\u0646\u064e",
    "text_norm": "\u0627\u0630 \u0642\u0627\u0644 \u0644\u0647\u0645 \u0627\u062e\u0648\u0647\u0645 \u0644\u0648\u0637 \u0627\u0644\u0627 \u062a\u062a\u0642\u0648\u0646"
