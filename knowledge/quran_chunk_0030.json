    "text": "\u0623\u064e\u062a\u064e\u0623\u0652\u062a\u064f\u0648\u0646\u064e \u0671\u0644\u0630\u0651\u064f\u0643\u0652\u0631\u064e\u0627\u0646\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0639\u064e\u0670\u0644\u064e\u0645\u0650\u064a\u0646\u064e",
    "text_norm": "\u0627\u062a\u0627\u062a\u0648\u0646 \u0627\u0644\u0630\u0643\u0631\u0627\u0646 \u0645\u0646 \u0627\u0644\u0639\u0644\u0645\u064a\u0646"
  },
