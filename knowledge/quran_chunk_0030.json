    "text": "\u0641\u064e\u0623\u064e\u062e\u064e\u0630\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0639\u064e\u0630\u064e\u0627\u0628\u064f \u06d7 \u0625\u0650\u0646\u0651\u064e \u0641\u0650\u0649 \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0644\u064e\u0621\u064e\u0627\u064a\u064e\u0629\u064b\u06ed \u06d6 \u0648\u064e\u0645\u064e\u0627 \u0643\u064e\u0627\u0646\u064e \u0623\u064e\u0643\u0652\u062b\u064e\u0631\u064f\u0647\u064f\u0645 \u0645\u0651\u064f\u0624\u0652\u0645\u0650\u0646\u0650\u064a\u0646\u064e",
