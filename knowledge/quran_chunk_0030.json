  },
  {
    "surah": 26,
    "ayah": 159,
    "text": "\u0648\u064e\u0625\u0650\u0646\u0651\u064e \u0631\u064e\u0628\u0651\u064e\u0643\u064e \u0644\u064e\u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0639\u064e\u0632\u0650\u064a\u0632\u064f \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064f",
    "text_norm": "\u0648\u0627\u0646 \u0631\u0628\u0643 \u0644\u0647\u0648 \u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0644\u0631\u062d\u064a\u0645"
  },
  {
