  },
  {
    "surah": 26,
    "ayah": 157,
    "text": "\u0641\u064e\u0639\u064e\u0642\u064e\u0631\u064f\u0648\u0647\u064e\u0627 \u0641\u064e\u0623\u064e\u0635\u0652\u0628\u064e\u062d\u064f\u0648\u0627\u06df \u0646\u064e\u0670\u062f\u0650\u0645\u0650\u064a\u0646\u064e",
    "text_norm": "\u0641\u0639\u0642\u0631\u0648\u0647\u0627 \u0641\u0627\u0635\u0628\u062d\u0648\u0627\u06df \u0646\u062f\u0645\u064a\u0646"
