    "text_norm": "\u0648\u062a\u0630\u0631\u0648\u0646 \u0645\u0627 \u062e\u0644\u0642 \u0644\u0643\u0645 \u0631\u0628\u0643\u0645 \u0645\u0646 \u0627\u0632\u0648\u062c\u0643\u0645 \u06da \u0628\u0644 \u0627\u0646\u062a\u0645 \u0642\u0648\u0645 \u0639\u0627\u062f\u0648\u0646"
