    "ayah": 160,
    "text": "\u0643\u064e\u0630\u0651\u064e\u0628\u064e\u062a\u0652 \u0642\u064e\u0648\u0652\u0645\u064f \u0644\u064f\u0648\u0637\u064d \u0671\u0644\u0652\u0645\u064f\u0631\u0652\u0633\u064e\u0644\u0650\u064a\u0646\u064e",
    "text_norm": "\u0643\u0630\u0628\u062a \u0642\u0648\u0645 \u0644\u0648\u0637 \u0627\u0644\u0645\u0631\u0633\u0644\u064a\u0646"
