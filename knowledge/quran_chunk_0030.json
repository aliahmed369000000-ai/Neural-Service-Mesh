    "text": "\u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064e\u0633\u0652\u0640\u0654\u064e\u0644\u064f\u0643\u064f\u0645\u0652 \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u0645\u0650\u0646\u0652 \u0623\u064e\u062c\u0652\u0631\u064d \u06d6 \u0625\u0650\u0646\u0652 \u0623\u064e\u062c\u0652\u0631\u0650\u0649\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0639\u064e\u0644\u064e\u0649\u0670 \u0631\u064e\u0628\u0651\u0650 \u0671\u0644\u0652\u0639\u064e\u0670\u0644\u064e\u0645\u0650\u064a\u0646\u064e",
    "text_norm": "\u0648\u0645\u0627 \u0627\u0633\u0644\u0643\u0645 \u0639\u0644\u064a\u0647 \u0645\u0646 \u0627\u062c\u0631 \u06d6 \u0627\u0646 \u0627\u062c\u0631\u0649 \u0627\u0644\u0627 \u0639\u0644\u0649 \u0631\u0628 \u0627\u0644\u0639\u0644\u0645\u064a\u0646"
  },
  {
    "surah": 26,
