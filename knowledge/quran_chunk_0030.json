    "text": "\u0648\u064e\u0644\u064e\u0627 \u062a\u064f\u0637\u0650\u064a\u0639\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0645\u0652\u0631\u064e \u0671\u0644\u0652\u0645\u064f\u0633\u0652\u0631\u0650\u0641\u0650\u064a\u0646\u064e",
    "text_norm": "\u0648\u0644\u0627 \u062a\u0637\u064a\u0639\u0648\u0627\u06df \u0627\u0645\u0631 \u0627\u0644\u0645\u0633\u0631\u0641\u064a\u0646"
  },
  {
    "surah": 26,
    "ayah": 152,
    "text": "\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064f\u0641\u0652\u0633\u0650\u062f\u064f\u0648\u0646\u064e \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u0644\u064e\u0627 \u064a\u064f\u0635\u0652\u0644\u0650\u062d\u064f\u0648\u0646\u064e",
    "text_norm": "\u0627\u0644\u0630\u064a\u0646 \u064a\u0641\u0633\u062f\u0648\u0646 \u0641\u0649 \u0627\u0644\u0627\u0631\u0636 \u0648\u0644\u0627 \u064a\u0635\u0644\u062d\u0648\u0646"
  },
  {
    "surah": 26,
    "ayah": 153,
    "text": "\u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0646\u0651\u064e\u0645\u064e\u0627\u0653 \u0623\u064e\u0646\u062a\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0645\u064f\u0633\u064e\u062d\u0651\u064e\u0631\u0650\u064a\u0646\u064e",
    "text_norm": "\u0642\u0627\u0644\u0648\u0627\u06df \u0627\u0646\u0645\u0627 \u0627\u0646\u062a \u0645\u0646 \u0627\u0644\u0645\u0633\u062d\u0631\u064a\u0646"
  },
  {
    "surah": 26,
    "ayah": 154,
    "text": "\u0645\u064e\u0627\u0653 \u0623\u064e\u0646\u062a\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0628\u064e\u0634\u064e\u0631\u064c\u06ed \u0645\u0651\u0650\u062b\u0652\u0644\u064f\u0646\u064e\u0627 \u0641\u064e\u0623\u0652\u062a\u0650 \u0628\u0650\u0640\u0654\u064e\u0627\u064a\u064e\u0629\u064d \u0625\u0650\u0646 \u0643\u064f\u0646\u062a\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0635\u0651\u064e\u0670\u062f\u0650\u0642\u0650\u064a\u0646\u064e",
    "text_norm": "\u0645\u0627 \u0627\u0646\u062a \u0627\u0644\u0627 \u0628\u0634\u0631\u06ed \u0645\u062b\u0644\u0646\u0627 \u0641\u0627\u062a \u0628\u0627\u064a\u0629 \u0627\u0646 \u0643\u0646\u062a \u0645\u0646 \u0627\u0644\u0635\u062f\u0642\u064a\u0646"
  },
  {
    "surah": 26,
    "ayah": 155,
    "text": "\u0642\u064e\u0627\u0644\u064e \u0647\u064e\u0670\u0630\u0650\u0647\u0650\u06e6 \u0646\u064e\u0627\u0642\u064e\u0629\u064c\u06ed \u0644\u0651\u064e\u0647\u064e\u0627 \u0634\u0650\u0631\u0652\u0628\u064c\u06ed \u0648\u064e\u0644\u064e\u0643\u064f\u0645\u0652 \u0634\u0650\u0631\u0652\u0628\u064f \u064a\u064e\u0648\u0652\u0645\u064d\u06e2 \u0645\u0651\u064e\u0639\u0652\u0644\u064f\u0648\u0645\u064d\u06e2",
    "text_norm": "\u0642\u0627\u0644 \u0647\u0630\u0647\u06e6 \u0646\u0627\u0642\u0629\u06ed \u0644\u0647\u0627 \u0634\u0631\u0628\u06ed \u0648\u0644\u0643\u0645 \u0634\u0631\u0628 \u064a\u0648\u0645\u06e2 \u0645\u0639\u0644\u0648\u0645\u06e2"
  },
  {
