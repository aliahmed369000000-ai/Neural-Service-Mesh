    "ayah": 167,
    "text": "\u0642\u064e\u0627\u0644\u064f\u0648\u0627\u06df \u0644\u064e\u0626\u0650\u0646 \u0644\u0651\u064e\u0645\u0652 \u062a\u064e\u0646\u062a\u064e\u0647\u0650 \u064a\u064e\u0670\u0644\u064f\u0648\u0637\u064f \u0644\u064e\u062a\u064e\u0643\u064f\u0648\u0646\u064e\u0646\u0651\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0645\u064f\u062e\u0652\u0631\u064e\u062c\u0650\u064a\u0646\u064e",
    "text_norm": "\u0642\u0627\u0644\u0648\u0627\u06df \u0644\u0626\u0646 \u0644\u0645 \u062a\u0646\u062a\u0647 \u064a\u0644\u0648\u0637 \u0644\u062a\u0643\u0648\u0646\u0646 \u0645\u0646 \u0627\u0644\u0645\u062e\u0631\u062c\u064a\u0646"
