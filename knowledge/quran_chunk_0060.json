    "text": "\u0641\u064e\u0623\u064e\u0645\u0651\u064e\u0627 \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064f \u0625\u0650\u0630\u064e\u0627 \u0645\u064e\u0627 \u0671\u0628\u0652\u062a\u064e\u0644\u064e\u0649\u0670\u0647\u064f \u0631\u064e\u0628\u0651\u064f\u0647\u064f\u06e5 \u0641\u064e\u0623\u064e\u0643\u0652\u0631\u064e\u0645\u064e\u0647\u064f\u06e5 \u0648\u064e\u0646\u064e\u0639\u0651\u064e\u0645\u064e\u0647\u064f\u06e5 \u0641\u064e\u064a\u064e\u0642\u064f\u0648\u0644\u064f \u0631\u064e\u0628\u0651\u0650\u0649\u0653 \u0623\u064e\u0643\u0652\u0631\u064e\u0645\u064e\u0646\u0650",
    "text_norm": "\u0641\u0627\u0645\u0627 \u0627\u0644\u0627\u0646\u0633\u0646 \u0627\u0630\u0627 \u0645\u0627 \u0627\u0628\u062a\u0644\u0649\u0647 \u0631\u0628\u0647\u06e5 \u0641\u0627\u0643\u0631\u0645\u0647\u06e5 \u0648\u0646\u0639\u0645\u0647\u06e5 \u0641\u064a\u0642\u0648\u0644 \u0631\u0628\u0649 \u0627\u0643\u0631\u0645\u0646"
  },
  {
    "surah": 89,
    "ayah": 16,
    "text": "\u0648\u064e\u0623\u064e\u0645\u0651\u064e\u0627\u0653 \u0625\u0650\u0630\u064e\u0627 \u0645\u064e\u0627 \u0671\u0628\u0652\u062a\u064e\u0644\u064e\u0649\u0670\u0647\u064f \u0641\u064e\u0642\u064e\u062f\u064e\u0631\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u0631\u0650\u0632\u0652\u0642\u064e\u0647\u064f\u06e5 \u0641\u064e\u064a\u064e\u0642\u064f\u0648\u0644\u064f \u0631\u064e\u0628\u0651\u0650\u0649\u0653 \u0623\u064e\u0647\u064e\u0670\u0646\u064e\u0646\u0650",
    "text_norm": "\u0648\u0627\u0645\u0627 \u0627\u0630\u0627 \u0645\u0627 \u0627\u0628\u062a\u0644\u0649\u0647 \u0641\u0642\u062f\u0631 \u0639\u0644\u064a\u0647 \u0631\u0632\u0642\u0647\u06e5 \u0641\u064a\u0642\u0648\u0644 \u0631\u0628\u0649 \u0627\u0647\u0646\u0646"
  },
  {
    "surah": 89,
