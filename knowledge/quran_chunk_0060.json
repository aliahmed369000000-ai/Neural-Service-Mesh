    "text_norm": "\u0648\u0644\u0627 \u062a\u062d\u0636\u0648\u0646 \u0639\u0644\u0649 \u0637\u0639\u0627\u0645 \u0627\u0644\u0645\u0633\u0643\u064a\u0646"
